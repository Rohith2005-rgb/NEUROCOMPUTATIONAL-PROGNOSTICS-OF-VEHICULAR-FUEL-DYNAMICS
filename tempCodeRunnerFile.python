def is_prime(num):
    if num<2:
        return false
    for i in range(2,int(num**0.5)+1):
        if num%1==0:
            return False
    return True
primes=[]
num=2
while len(primes)<20:
    if is_prime(num):
        primes.append(num)
    num=num+1
print("the first 20 prime numbers:",primes)